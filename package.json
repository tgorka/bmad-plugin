{
  "name": "bmad-plugin",
  "version": "6.5.0.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --no-errors-on-unmatched .",
    "lint:staged": "biome check --write --staged --no-errors-on-unmatched",
    "validate": "bun scripts/validate-upstream-coverage.ts",
    "sync": "bun scripts/sync-from-installer.ts",
    "sync:dry": "bun scripts/sync-from-installer.ts --dry-run",
    "update-readme": "bun scripts/update-readme-version.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "latest",
    "husky": "^9",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
